# PostgreSQL connection string. The backend logs a warning and continues
# without persistence when the database is unreachable (local dev mode).
DATABASE_URL=postgres://git_viz:secret_password@localhost:5432/git_interactive_history?sslmode=disable

# HTTP listen port (default 8080).
PORT=8080

# HS256 signing key for internal JWTs. The value below is the documented
# dev fallback baked into src/auth/jwt.go — always override in production.
JWT_SECRET=super-secret-system-key-rotate-in-production

# GitHub OAuth2 application credentials (https://github.com/settings/developers).
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# Must match the OAuth app's authorization callback URL.
OAUTH_REDIRECT_URL=http://localhost:8080/api/v1/auth/github/callback

# PostgreSQL connection string. The backend logs a warning and continues
# without persistence when the database is unreachable (local dev mode).
DATABASE_URL=postgres://git_viz:secret_password@localhost:5432/git_interactive_history?sslmode=disable

# HTTP listen port (default 8080).
PORT=8080

# HS256 signing key for internal JWTs. The value below is the documented
# dev fallback baked into src/auth/jwt.go — always override in production.
JWT_SECRET=super-secret-system-key-rotate-in-production

# GitHub OAuth2 application credentials (https://github.com/settings/developers).
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

# Must match the OAuth app's authorization callback URL.
OAUTH_REDIRECT_URL=http://localhost:8080/api/v1/auth/github/callback

# AES-256-GCM master key for repository credentials at rest (base64 of 32
# random bytes). When unset, src/crypto.MasterKey falls back to an insecure
# dev key and logs a warning — production MUST set this (Vault plugs in here).
# Generate with: head -c 32 /dev/urandom | base64
REPO_CRED_KEY=VeqEVPI9jbJeE28BRxNGix8bfSlP8vcD4vB0bISLUVA=

# HashiCorp Vault secrets layer for the repo-credential master key. When BOTH
# VAULT_ADDR and VAULT_TOKEN are set, src/secrets.ResolveMasterKey reads the
# key from Vault FIRST and FAILS CLOSED on any Vault error (it does NOT fall
# back to REPO_CRED_KEY/dev key — a misconfigured Vault must not silently
# downgrade security). Left empty below so the REPO_CRED_KEY/dev path stays the
# default locally. Vault is KV v2: VAULT_KV_PATH is the data API path and the
# operator seeds `repo_cred_key` (base64 32 bytes):
#   vault kv put secret/git-viz repo_cred_key=<base64>
VAULT_ADDR=
VAULT_TOKEN=
VAULT_KV_PATH=secret/data/git-viz

# Fallback org/team name assigned to OAuth users who belong to no GitHub
# organization (src/auth maps the user's primary org to a team).
OAUTH_DEFAULT_ORG=default-team

# Shared secret used to verify GitHub webhook deliveries (POST
# /api/v1/webhooks/github) via the X-Hub-Signature-256 HMAC-SHA256 header.
# DEV ONLY: when this is UNSET the backend logs a warning and SKIPS signature
# verification so local testing works without a configured secret. Production
# MUST set this to the value configured on the GitHub webhook.
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret

# Meilisearch full-text search backend. The backend degrades gracefully when
# Meili is unreachable: indexing is best-effort and /api/v1/search returns 503.
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=your_meili_master_key

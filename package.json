{
  "name": "dabiran",
  "version": "1.0.0",
  "private": true,
  "description": "Collaborative Git Visualization Platform monorepo root binding npm workspaces across apps and shared packages.",
  "workspaces": [
    "apps/frontend",
    "packages/shared-types",
    "packages/utils",
    "packages/wasm-math"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "build:wasm": "npm run build:wasm -w @git-viz/wasm-math",
    "build": "npm run build --workspaces --if-present"
  }
}
